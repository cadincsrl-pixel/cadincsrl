PORT=3001
NODE_ENV=development

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FRONTEND_URL=http://localhost:3000

# Feature flag del rollout de RPCs transaccionales para resolver ítems
# de solicitud_compra (resolver_item_compra / resolver_item_despacho).
# Default 'false' (o cualquier otro valor) → camino legacy no-transaccional.
# Setear a 'true' para activar las RPCs. Flag pensado para rollback
# instantáneo vía restart del backend.
USE_RPC_RESOLVER=false