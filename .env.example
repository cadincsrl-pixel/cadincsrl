PORT=3001
NODE_ENV=development

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FRONTEND_URL=http://localhost:3000

# Feature flag del rollout de RPCs transaccionales para resolver ítems
# de solicitud_compra (resolver_item_compra / resolver_item_despacho).
# Default 'false' (o cualquier otro valor) → camino legacy no-transaccional.
# Setear a 'true' para activar las RPCs. Flag pensado para rollback
# instantáneo vía restart del backend.
USE_RPC_RESOLVER=false

# ── GPS Mobile Quest ─────────────────────────────────────────────────
# Cliente para sincronización de km y posición desde el GPS satelital.
# Si MOBILE_QUEST_BASE_URL queda vacío, usa el default productivo.
MOBILE_QUEST_BASE_URL=https://mobilequest.com.ar/gis-api
MOBILE_QUEST_USERNAME=
MOBILE_QUEST_PASSWORD=

# Secret compartido para autenticar el endpoint del cron de sync GPS.
# Generar con: openssl rand -hex 32
# Vercel Cron envía automáticamente este valor como `Authorization: Bearer ${CRON_SECRET}`
# si está configurado como variable de entorno del proyecto.
CRON_SECRET=

# ── Google Maps Platform ─────────────────────────────────────────────
# Distance Matrix API + Geocoding API. Habilitar billing en GCP y crear
# API key restringida a esos 2 servicios + dominio del backend.
# Free tier: $200 USD/mes (~40k elementos de Distance Matrix).
GOOGLE_MAPS_API_KEY=